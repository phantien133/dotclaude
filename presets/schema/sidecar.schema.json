{
  "type": "object",
  "properties": {
    "source": {
      "type": "object",
      "properties": {
        "repo": {
          "type": "string",
          "format": "uri"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "repo",
        "commit",
        "path",
        "ref"
      ],
      "additionalProperties": false
    },
    "imported_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "modified": {
      "type": "boolean"
    },
    "modifications": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "required": {
          "type": "object",
          "properties": {
            "agents": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "skills": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "commands": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "hooks": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "rules": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "agents": [],
            "skills": [],
            "commands": [],
            "hooks": [],
            "rules": []
          }
        },
        "optional": {
          "type": "object",
          "properties": {
            "agents": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "skills": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "commands": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "hooks": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "rules": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "agents": [],
            "skills": [],
            "commands": [],
            "hooks": [],
            "rules": []
          }
        },
        "external": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "npm",
                  "system_binary",
                  "python_pkg"
                ]
              },
              "version": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "type"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "additionalProperties": false,
      "default": {
        "required": {
          "agents": [],
          "skills": [],
          "commands": [],
          "hooks": [],
          "rules": []
        },
        "optional": {
          "agents": [],
          "skills": [],
          "commands": [],
          "hooks": [],
          "rules": []
        },
        "external": []
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "propertyNames": {
        "minLength": 1
      },
      "default": {}
    }
  },
  "required": [
    "source",
    "imported_at",
    "license",
    "modified"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://phantien133.github.io/dotclaude/schema/sidecar.schema.json",
  "title": "dotclaude Sidecar (provenance + dependencies)"
}
