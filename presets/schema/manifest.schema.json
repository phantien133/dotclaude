{
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "installed_at": {
      "type": "string",
      "format": "date-time"
    },
    "presets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "core",
              "framework",
              "purpose"
            ]
          }
        },
        "required": [
          "name",
          "version",
          "kind"
        ],
        "additionalProperties": false
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "agent",
              "skill",
              "command",
              "hook",
              "rule"
            ]
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "target_path": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "symlink",
              "copy"
            ]
          },
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "source_commit": {
            "type": [
              "string",
              "null"
            ]
          },
          "preset": {
            "type": "string",
            "minLength": 1
          },
          "auto_included": {
            "type": "boolean",
            "default": false
          },
          "required_by": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        },
        "required": [
          "type",
          "id",
          "target_path",
          "mode",
          "source_path",
          "source_commit",
          "preset"
        ],
        "additionalProperties": false
      }
    },
    "settings_patches": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "preset": {
            "type": "string",
            "minLength": 1
          },
          "patch_keys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "patch": {
            "type": "object",
            "additionalProperties": {}
          }
        },
        "required": [
          "preset"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "external_deps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "npm",
              "system_binary",
              "python_pkg"
            ]
          },
          "version": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "found": {
            "type": "boolean"
          },
          "detected_version": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          },
          "requested_by": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        },
        "required": [
          "name",
          "type",
          "found"
        ],
        "additionalProperties": false
      },
      "default": []
    }
  },
  "required": [
    "schema_version",
    "installed_at",
    "presets",
    "components"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://phantien133.github.io/dotclaude/schema/manifest.schema.json",
  "title": "dotclaude Install Manifest"
}
