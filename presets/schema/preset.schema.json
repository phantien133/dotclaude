{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "core",
        "framework",
        "purpose"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "extends": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "components": {
      "type": "object",
      "properties": {
        "agents": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "hooks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false,
      "default": {
        "agents": [],
        "skills": [],
        "commands": [],
        "hooks": [],
        "rules": []
      }
    },
    "settings_patch": {
      "type": "object",
      "additionalProperties": {},
      "default": {}
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    }
  },
  "required": [
    "name",
    "kind",
    "description",
    "version"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://phantien133.github.io/dotclaude/schema/preset.schema.json",
  "title": "dotclaude Preset"
}
