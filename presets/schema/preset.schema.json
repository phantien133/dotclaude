{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "core",
        "framework",
        "purpose"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "extends": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "components": {
      "type": "object",
      "properties": {
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "enum": [
                  "everything-claude-code",
                  "anthropic-skills",
                  "dotclaude-self",
                  "workflow",
                  "figma",
                  "private"
                ]
              }
            },
            "required": [
              "name",
              "source"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "enum": [
                  "everything-claude-code",
                  "anthropic-skills",
                  "dotclaude-self",
                  "workflow",
                  "figma",
                  "private"
                ]
              }
            },
            "required": [
              "name",
              "source"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "enum": [
                  "everything-claude-code",
                  "anthropic-skills",
                  "dotclaude-self",
                  "workflow",
                  "figma",
                  "private"
                ]
              }
            },
            "required": [
              "name",
              "source"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "hooks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "enum": [
                  "everything-claude-code",
                  "anthropic-skills",
                  "dotclaude-self",
                  "workflow",
                  "figma",
                  "private"
                ]
              }
            },
            "required": [
              "name",
              "source"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "enum": [
                  "everything-claude-code",
                  "anthropic-skills",
                  "dotclaude-self",
                  "workflow",
                  "figma",
                  "private"
                ]
              }
            },
            "required": [
              "name",
              "source"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "additionalProperties": false,
      "default": {
        "agents": [],
        "skills": [],
        "commands": [],
        "hooks": [],
        "rules": []
      }
    },
    "settings_patch": {
      "type": "object",
      "additionalProperties": {},
      "default": {}
    },
    "external_setup": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "mcp_server",
              "npm_global",
              "system_binary",
              "pip_package",
              "claude_plugin"
            ]
          },
          "standalone": {
            "type": "boolean",
            "default": true
          },
          "install_hint": {
            "type": "string"
          },
          "complexity": {
            "type": "string",
            "enum": [
              "simple",
              "moderate",
              "complex"
            ],
            "default": "simple"
          },
          "docs_url": {
            "type": "string",
            "format": "uri"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "kind"
        ],
        "additionalProperties": false
      },
      "default": []
    },
    "recommended_install_level": {
      "type": "string",
      "enum": [
        "user",
        "project"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "use_case_tags": {
      "type": "object",
      "properties": {
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "project_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "stacks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "use_cases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false,
      "default": {
        "roles": [],
        "project_types": [],
        "stacks": [],
        "use_cases": []
      }
    }
  },
  "required": [
    "name",
    "kind",
    "description",
    "version"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://phantien133.github.io/dotclaude/schema/preset.schema.json",
  "title": "dotclaude Preset"
}
