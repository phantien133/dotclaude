        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "event": {
            "type": "string",
            "enum": [
              "PreToolUse",
              "PostToolUse",
              "Stop",
              "PreCompact"
            ]
          },
          "matcher": {
            "type": "string"
          },
          "preset": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "file",
          "description",
          "event",
          "matcher",
          "preset"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "hooks"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://phantien133.github.io/dotclaude/schema/hooks-manifest.schema.json",
  "title": "dotclaude Hooks Manifest"
