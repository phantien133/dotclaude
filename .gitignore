# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Upstream submodules — only present on `develop` branch; master is the lean
# release branch consumed by the marketplace, so any `upstream/` content here
# is local-only and must never be committed.
upstream/

# Private overlays (per CQ-4a — gitignored, each top package has its own private/)
/claudekit/private/
/presets/private/
/plugins/private/

# Plugin build artifacts — committed selectively when publishing to marketplace repo.
# Uncomment to gitignore all built plugin bundles:
# /plugins/*/

# Backup files from installer (CQ-5c — backup-then-overwrite default)
*.bak.*

# Installer-managed project Claude config (CQ-5e)
# .dotclaude-manifest.yaml: per-target installer manifest, not repo
# settings.local.json: machine-local permissions
# skills/: installer-managed symlinks, recreated via pnpm install:project --force
.claude/.dotclaude-manifest.yaml
.claude/settings.local.json
.claude/skills/

# TypeScript / Bun
node_modules/
dist/
*.tsbuildinfo

# Python bytecode (skill-creator scripts)
__pycache__/
*.pyc

# skill-creator eval workspaces (local iteration artifacts)
claudekit/skills/skill-creator/*-workspace/

# Planning documents (local only — not tracked in git)
docs/plan/

# Test scratch
.tmp/
.cache/
coverage/

